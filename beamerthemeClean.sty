% beamerthemeClean.sty
% A minimalist Beamer theme, port of the Touying "quarto-clean" theme.
% Load with \usetheme{Clean} (file must sit next to your .tex, or on TEXMF path).
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemeClean}[2026/06/30 v0.2 Clean Beamer theme]

\mode<presentation>

\RequirePackage{amssymb}   % \blacktriangleright for list markers
\RequirePackage{etoolbox}
% ORCID badge (tikz-drawn, pdflatex-safe) on the title page. Loaded defensively
% so \usetheme{Clean} still works on TeX installs without orcidlink — decks that
% never render an ORCID id simply get a no-op \orcidlink and compile fine.
\IfFileExists{orcidlink.sty}{\RequirePackage{orcidlink}}{%
  \providecommand{\orcidlink}[1]{}}
% Author names on the title page use Roboto Regular (400) so they sit heavier
% than the light body, matching the Typst theme. A no-op fallback keeps the
% theme loadable without the roboto package (the real \robotoregular, defined
% by roboto via \def, overrides this when that package is present).
\providecommand{\robotoregular}{}

% ----------------------------------------------------------------------
% Colours  (mirrored from the Typst clean theme)
%   jet/foreground #131516 · primary #107895 · secondary #9A2515
% ----------------------------------------------------------------------
\definecolor{cleanJet}{HTML}{131516}
\definecolor{cleanPrimary}{HTML}{107895}
\definecolor{cleanSecondary}{HTML}{9A2515}
\definecolor{cleanBg}{HTML}{FFFFFF}

\setbeamercolor{normal text}{fg=cleanJet, bg=cleanBg}
\setbeamercolor{alerted text}{fg=cleanSecondary}
\setbeamercolor{structure}{fg=cleanPrimary}

\setbeamercolor{title}{fg=cleanJet}
\setbeamercolor{subtitle}{fg=cleanPrimary}
\setbeamercolor{author}{fg=cleanJet}
\setbeamercolor{institute}{fg=cleanJet}
\setbeamercolor{date}{fg=cleanJet}

\setbeamercolor{frametitle}{fg=cleanJet, bg=}
\setbeamercolor{framesubtitle}{fg=cleanPrimary}

\setbeamercolor{itemize item}{fg=cleanPrimary}
\setbeamercolor{itemize subitem}{fg=cleanPrimary}
\setbeamercolor{itemize subsubitem}{fg=cleanPrimary}
\setbeamercolor{enumerate item}{fg=cleanPrimary}
\setbeamercolor{enumerate subitem}{fg=cleanPrimary}
\setbeamercolor{enumerate subsubitem}{fg=cleanPrimary}

\setbeamercolor{section title}{fg=cleanPrimary}
\setbeamercolor{footline}{fg=cleanJet}

% Blocks: keep all three variants inside the four-token palette. Beamer's
% default "example" colour is green!50!black, which is off-palette; standard and
% alert blocks already inherit structure (primary) and alerted text (secondary).
% Bodies stay jet-on-white.
\setbeamercolor{block title}{fg=cleanPrimary}
\setbeamercolor{block title alerted}{fg=cleanSecondary}
\setbeamercolor{block title example}{fg=cleanPrimary}
\setbeamercolor{example text}{fg=cleanPrimary}

% Bibliography (works with biblatex or classic bibtex output): drop the
% default reference icon and render entries small, in the foreground colour.
\setbeamertemplate{bibliography item}{}
\setbeamercolor{bibliography entry author}{fg=cleanJet}
\setbeamercolor{bibliography entry title}{fg=cleanJet}
\setbeamercolor{bibliography entry location}{fg=cleanJet}
\setbeamercolor{bibliography entry note}{fg=cleanJet}
\setbeamerfont{bibliography entry author}{size=\footnotesize}
\setbeamerfont{bibliography entry title}{size=\footnotesize}
\setbeamerfont{bibliography entry location}{size=\footnotesize}
\setbeamerfont{bibliography entry note}{size=\footnotesize}

% Figure captions: small, with a primary-coloured "Figure:" label — matches
% the minimalist Typst look rather than Beamer's default boxed caption.
\setbeamertemplate{caption label separator}{: }
\setbeamercolor{caption name}{fg=cleanPrimary}
\setbeamerfont{caption}{size=\footnotesize}
\setbeamerfont{caption name}{size=\footnotesize, series=\mdseries}

% ----------------------------------------------------------------------
% Fonts  (weights/sizes; actual typefaces are chosen in the .tex preamble)
%   Target: Roboto Light for text/headings, Fira Mono for code.
% ----------------------------------------------------------------------
\setbeamerfont{title}{size=\LARGE, series=\mdseries}
\setbeamerfont{subtitle}{size=\large, shape=\itshape, series=\mdseries}
\setbeamerfont{author}{size=\normalsize, series=\mdseries}
\setbeamerfont{institute}{size=\small, shape=\itshape}
\setbeamerfont{date}{size=\small}
\setbeamerfont{frametitle}{size=\Large, series=\mdseries}
\setbeamerfont{framesubtitle}{size=\large, shape=\itshape, series=\mdseries}
\setbeamerfont{footline}{size=\scriptsize}
\setbeamerfont{section title}{size=\Huge, series=\bfseries}

% ----------------------------------------------------------------------
% Chrome: no navigation symbols, left-aligned, generous margins
% ----------------------------------------------------------------------
\setbeamertemplate{navigation symbols}{}
\setbeamersize{text margin left=2em, text margin right=2em}
\raggedright

% ----------------------------------------------------------------------
% List markers
%   itemize  level 1: filled right triangle · level 2+: arrow (as in Typst)
%   enumerate level 1: 1. · level 2: i. · level 3: a.  (all primary)
% ----------------------------------------------------------------------
\setbeamertemplate{itemize item}%
  {\small\textcolor{cleanPrimary}{$\blacktriangleright$}}
\setbeamertemplate{itemize subitem}%
  {\textcolor{cleanPrimary}{$\rightarrow$}}
\setbeamertemplate{itemize subsubitem}%
  {\textcolor{cleanPrimary}{$\rightarrow$}}

% Format each level's own counter so nesting reads 1. / i. / a.
% (\insertenumlabel is always arabic, so it can't give roman/alpha sublevels.)
\setbeamertemplate{enumerate item}%
  {\textcolor{cleanPrimary}{\arabic{enumi}.}}
\setbeamertemplate{enumerate subitem}%
  {\textcolor{cleanPrimary}{\roman{enumii}.}}
\setbeamertemplate{enumerate subsubitem}%
  {\textcolor{cleanPrimary}{\alph{enumiii}.}}

% ----------------------------------------------------------------------
% Frame title (left aligned) with optional italic primary subtitle
% ----------------------------------------------------------------------
\setbeamertemplate{frametitle}{%
  \vspace*{1em}%
  {\usebeamerfont{frametitle}\usebeamercolor[fg]{frametitle}\insertframetitle\par}%
  \ifx\insertframesubtitle\@empty\else
    \vspace*{0.15em}%
    {\usebeamerfont{framesubtitle}\usebeamercolor[fg]{framesubtitle}\insertframesubtitle\par}%
  \fi
  \vspace*{0.5em}%
}

% ----------------------------------------------------------------------
% Footline:  slide x / y  (bottom right)
% ----------------------------------------------------------------------
\setbeamertemplate{footline}{%
  \hbox{%
    \begin{beamercolorbox}[wd=\paperwidth, ht=2.5ex, dp=1.5ex,
                           leftskip=2em, rightskip=2em]{footline}%
      \usebeamerfont{footline}%
      \hfill\insertframenumber\,/\,\inserttotalframenumber%
    \end{beamercolorbox}%
  }%
}

% ----------------------------------------------------------------------
% Author grid (title slide) — optional richer API:
%   \cleanauthor{name}{orcid}{email}{affiliation}
% Each call adds one author cell; the title page lays them out in a grid of
% up to three columns (mirrors the Typst clean theme). The orcid, email and
% affiliation arguments are each optional — leave the brace group empty to
% omit that line. If no \cleanauthor is given, the title page falls back to
% the plain \insertauthor / \insertinstitute layout.
% ----------------------------------------------------------------------
\newcounter{cleanauthors}
\newcounter{cleancol}
\newlength{\cleancolwd}
\newcommand{\clean@authorcells}{}

\newcommand{\cleanauthor}[4]{%
  \stepcounter{cleanauthors}%
  \appto\clean@authorcells{\clean@authorcell{#1}{#2}{#3}{#4}}%
}

% One author cell: name (+ ORCID badge), email (mailto link), affiliation.
\newcommand{\clean@authorcell}[4]{%
  \stepcounter{cleancol}%
  \begin{minipage}[t]{\cleancolwd}%
    \raggedright
    {\usebeamerfont{author}\usebeamercolor[fg]{author}\robotoregular
     #1\ifblank{#2}{}{~\orcidlink{#2}}\par}%
    \ifblank{#3}{}{{\footnotesize\itshape
      \href{mailto:#3}{\textcolor{cleanJet}{#3}}\par}}%
    \ifblank{#4}{}{{\small\itshape\textcolor{cleanJet}{#4}\par}}%
  \end{minipage}%
  \ifnum\value{cleancol}<\cleanNcols\relax
    \hfill
  \else
    \par\vspace{1.5em}\setcounter{cleancol}{0}%
  \fi
}

% Pad the final (partial) row with empty cells so every row has exactly
% \cleanNcols column slots. Without this, a last row of two cells in a 3-column
% grid (5, 8, 11... authors) is "[A]\hfill[B]\hfill", and the equal \hfill glue
% drifts B toward the slide centre instead of seating it under column 2.
% Pads go into \clean@gridcells (a per-render copy), never into
% \clean@authorcells itself, so rendering the title page more than once
% doesn't accumulate phantom cells.
\newcommand{\clean@padgrid}{%
  \@tempcnta=\value{cleanauthors}\relax
  \loop\ifnum\@tempcnta>\cleanNcols\relax \advance\@tempcnta-\cleanNcols\relax\repeat
  \ifnum\@tempcnta<\cleanNcols\relax
    \@tempcntb=\cleanNcols\relax \advance\@tempcntb-\@tempcnta\relax
    \loop\ifnum\@tempcntb>0\relax
      \appto\clean@gridcells{\clean@authorcell{}{}{}{}}%
      \advance\@tempcntb-1\relax
    \repeat
  \fi
}

% Lay the accumulated cells out in min(n,3) equal-width columns.
\newcommand{\clean@rendergrid}{%
  \edef\cleanNcols{\ifnum\value{cleanauthors}<3 \number\value{cleanauthors}\else3\fi}%
  \setlength{\cleancolwd}{\dimexpr\textwidth/\cleanNcols-1.5em\relax}%
  \setcounter{cleancol}{0}%
  \let\clean@gridcells\clean@authorcells
  \clean@padgrid
  \clean@gridcells\par
}

% ----------------------------------------------------------------------
% Title page
% ----------------------------------------------------------------------
\setbeamertemplate{title page}{%
  \vfill
  {\usebeamerfont{title}\usebeamercolor[fg]{title}\inserttitle\par}%
  \ifx\insertsubtitle\@empty\else
    \vspace*{0.3em}%
    {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle\par}%
  \fi
  \vspace*{1.5em}%
  \ifnum\value{cleanauthors}>0
    \clean@rendergrid
    % A document-level \institute{...} still shows beneath the grid (per-author
    % affiliation goes in \cleanauthor's 4th argument).
    \ifx\insertinstitute\@empty\else
      \vspace*{0.2em}%
      {\usebeamerfont{institute}\usebeamercolor[fg]{institute}\insertinstitute\par}%
    \fi
  \else
    {\usebeamerfont{author}\usebeamercolor[fg]{author}\insertauthor\par}%
    \ifx\insertinstitute\@empty\else
      \vspace*{0.2em}%
      {\usebeamerfont{institute}\usebeamercolor[fg]{institute}\insertinstitute\par}%
    \fi
  \fi
  \vspace*{0.9em}%
  {\usebeamerfont{date}\usebeamercolor[fg]{date}\insertdate\par}%
  \vfill
}

% ----------------------------------------------------------------------
% Section slide (mirrors Touying's "= Section" auto slide)
% ----------------------------------------------------------------------
\setbeamertemplate{section page}{%
  \vfill
  {\usebeamerfont{section title}\usebeamercolor[fg]{section title}%
   \insertsectionhead\par}%
  \vfill
}
\AtBeginSection[]{%
  \begin{frame}[plain, noframenumbering]
    \sectionpage
  \end{frame}%
}

% ----------------------------------------------------------------------
% Title slide: chrome-free, matching the Typst reference. \maketitle wraps
% \titlepage in a [plain, noframenumbering] frame, so the title page shows no
% footer/slide number and the first *content* slide is numbered "1 / N" (not
% "2 / N"). Consistent with the [plain] section slides above.
% ----------------------------------------------------------------------
\renewcommand{\maketitle}{%
  \ifbeamer@inframe
    \titlepage
  \else
    \begin{frame}[plain, noframenumbering]\titlepage\end{frame}%
  \fi
}

\mode<all>
